{
    "attributes": {
        "author": [
            "Elastic"
        ],
        "description": "Detects AI API servers (Ollama, LM Studio, LocalAI, etc.) listening on non-loopback network addresses. A network-exposed AI server is reachable from other hosts, creating risk of data exfiltration, prompt injection, and unauthorized access to model capabilities. This rule triggers on osquery results from the AI Asset Discovery pack's ai_listening_ports query.",
        "from": "now-70m",
        "index": [
            "logs-osquery_manager.result*"
        ],
        "language": "kuery",
        "license": "Elastic License v2",
        "name": "Network-Exposed AI Server Detected",
        "query": "event.dataset:\"osquery.ai_discovery\" AND tags:\"network_exposure\" AND server.port:(11434 OR 1234 OR 4891 OR 1337 OR 5001 OR 7860) AND NOT server.address:(\"127.0.0.1\" OR \"::1\")",
        "related_integrations": [
            {
                "package": "osquery_manager",
                "version": "^1.0.0"
            }
        ],
        "required_fields": [
            {
                "ecs": true,
                "name": "event.dataset",
                "type": "keyword"
            },
            {
                "ecs": true,
                "name": "server.address",
                "type": "keyword"
            },
            {
                "ecs": true,
                "name": "server.port",
                "type": "long"
            },
            {
                "ecs": true,
                "name": "process.name",
                "type": "keyword"
            },
            {
                "ecs": true,
                "name": "tags",
                "type": "keyword"
            }
        ],
        "risk_score": 73,
        "rule_id": "a1b2c3d4-e5f6-4a7b-8c9d-0e1f2a3b4c5d",
        "severity": "high",
        "tags": [
            "Domain: Endpoint",
            "Use Case: Shadow AI Discovery",
            "Tactic: Discovery",
            "Data Source: Osquery",
            "OS: macOS",
            "OS: Linux",
            "OS: Windows"
        ],
        "threat": [
            {
                "framework": "MITRE ATT&CK",
                "tactic": {
                    "id": "TA0007",
                    "name": "Discovery",
                    "reference": "https://attack.mitre.org/tactics/TA0007/"
                },
                "technique": [
                    {
                        "id": "T1046",
                        "name": "Network Service Discovery",
                        "reference": "https://attack.mitre.org/techniques/T1046/"
                    }
                ]
            }
        ],
        "type": "query",
        "version": 1
    },
    "id": "a1b2c3d4-e5f6-4a7b-8c9d-0e1f2a3b4c5d_1",
    "type": "security-rule"
}
